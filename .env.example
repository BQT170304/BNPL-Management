# Persistence: "memory" (no infra), "sqlite" (local file), or "postgres"
PERSISTENCE=sqlite
SQLITE_PATH=bnpl.db
DATABASE_URL=postgresql+asyncpg://bnpl:bnpl@localhost:5432/bnpl
DATABASE_URL_TEST=postgresql+asyncpg://bnpl:bnpl@localhost:5432/bnpl_test

# Bedrock: when disabled, the deterministic scorer is always used
BEDROCK_ENABLED=false
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Engine config
ALLOCATION_STRATEGY=weighted   # "weighted" or "even"
EFR_SAFE_MONTHS=3
SCORE_WEIGHT_CASHFLOW=0.35
SCORE_WEIGHT_GOAL=0.35
SCORE_WEIGHT_EFR=0.20
SCORE_WEIGHT_DTI=0.10

# Auth (demo bearer-token auth; disable to leave the API open)
AUTH_ENABLED=true
AUTH_USERNAME=nguyenvana
AUTH_PASSWORD=123456
AUTH_TOKEN=demo-token-bnpl

# Forecasting (Prophet cash-flow forecast; falls back to a naive forecaster)
TRANSACTIONS_CSV_PATH=data/transactions_labeled.csv
FORECAST_HORIZON_DAYS=90
FORECAST_MIN_ACTIVE_DAYS=20
PROPHET_ENABLED=true
DEMO_CIF=10000327

# Local hosted LLM (OpenAI-compatible, e.g. Qwen3-14B)
# Set LOCAL_LLM_ENABLED=true to activate; used BEFORE Bedrock in scorer chain
LOCAL_LLM_ENABLED=true
LOCAL_LLM_URL=...
LOCAL_LLM_AUTH=...
LOCAL_LLM_MODEL=Qwen3-14B

# PD model trained on Taiwan Credit Card Default dataset
# Run: python scripts/train_pd_model.py  to (re)generate
ML_ENABLED=true
ML_MODEL_PATH=models/pd_model.pkl

# CORS (add port 5174 for Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
